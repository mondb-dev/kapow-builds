# Board Dockerfile — build context is repo root
FROM node:22-alpine

WORKDIR /app

# Copy board + shared schema
COPY board/package.json board/package-lock.json* board/
COPY db/prisma board/prisma

WORKDIR /app/board

RUN npm install --ignore-scripts
RUN npx prisma generate

COPY board/ .
RUN npm run build

EXPOSE ${PORT:-3005}

CMD ["npm", "run", "start"]
