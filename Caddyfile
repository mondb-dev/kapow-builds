# Replace with your domain or use :80 for HTTP-only
{$KAPOW_DOMAIN:kapow.example.com} {
	# Board UI
	handle /board* {
		reverse_proxy board:3005
	}

	# Agent API endpoints
	handle /api/planner/* {
		uri strip_prefix /api/planner
		reverse_proxy planner:3001
	}

	handle /api/builder/* {
		uri strip_prefix /api/builder
		reverse_proxy builder:3002
	}

	handle /api/qa/* {
		uri strip_prefix /api/qa
		reverse_proxy qa:3003
	}

	handle /api/gate/* {
		uri strip_prefix /api/gate
		reverse_proxy gate:3004
	}

	handle /api/technician/* {
		uri strip_prefix /api/technician
		reverse_proxy technician:3006
	}

	handle /api/security/* {
		uri strip_prefix /api/security
		reverse_proxy security:3007
	}

	handle /api/comms/* {
		uri strip_prefix /api/comms
		reverse_proxy comms:3008
	}

	# Actions orchestrator (default)
	handle /* {
		reverse_proxy actions:3000
	}
}
