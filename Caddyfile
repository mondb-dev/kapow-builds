# Kapow Reverse Proxy — 3-service architecture
# Only the board UI is public. Pipeline and technician are internal only.

{$KAPOW_DOMAIN:kapow.example.com} {

	# Board API routes (auth handled by NextAuth)
	handle /api/* {
		reverse_proxy board:3005
	}

	# Block direct access to internal services
	handle /pipeline {
		respond "Forbidden" 403
	}
	handle /plan {
		respond "Forbidden" 403
	}

	# Default: board UI
	handle /* {
		reverse_proxy board:3005
	}
}
