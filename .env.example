# ═══════════════════════════════════════════════════════════════════════
# Kapow Environment Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════

# ── AI Provider ───────────────────────────────────────────────────────

# Which AI provider to use: "anthropic" (default) or "gemini"
AI_PROVIDER=anthropic

# Anthropic API key (required if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Gemini API key (required if AI_PROVIDER=gemini)
# GEMINI_API_KEY=...

# Optional per-service AI key overrides
# If set, these override the shared keys only for that service.
# BUILDER_ANTHROPIC_API_KEY=
# BUILDER_GEMINI_API_KEY=
# TECHNICIAN_ANTHROPIC_API_KEY=
# TECHNICIAN_GEMINI_API_KEY=

# Optional model overrides (defaults based on provider)
# AI_MODEL_STRONG=claude-opus-4-6         # or gemini-2.5-pro
# AI_MODEL_BALANCED=claude-sonnet-4-6     # or gemini-2.5-flash
# AI_MODEL_FAST=claude-haiku-4-5-20251001 # or gemini-2.0-flash

# ── Required ──────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kapow

# ── Board Authentication (GitHub OAuth) ───────────────────────────────

# Random string for NextAuth session encryption
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Shared internal credential for service-to-service APIs
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# Protects the public /api/comms/webhook endpoint
COMMS_WEBHOOK_SECRET=

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers → OAuth Apps → New
# Callback URL: http://localhost:3005/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Builder Integrations (optional) ──────────────────────────────────

# GitHub personal access token — for creating repos and pushing code
GITHUB_TOKEN=

# Vercel deployment token
VERCEL_TOKEN=

# Netlify deployment token
NETLIFY_TOKEN=

# ── Slack Bot (optional) ─────────────────────────────────────────────

# Slack Bot OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=

# Slack Signing Secret
SLACK_SIGNING_SECRET=

# Slack App Token for Socket Mode (starts with xapp-, optional)
# If set, the bot uses Socket Mode (no public URL needed for development)
# If not set, configure Event Subscriptions URL instead
SLACK_APP_TOKEN=

# Optional board access controls (comma-separated)
# BOARD_ALLOWED_EMAILS=
# BOARD_ALLOWED_USER_IDS=
# BOARD_ADMIN_EMAILS=
# BOARD_ADMIN_USER_IDS=

# ── Docker / Production ──────────────────────────────────────────────

# Domain for Caddy HTTPS reverse proxy
KAPOW_DOMAIN=localhost

# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=postgres

# CORS origins for the actions HTTP API
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3005

# ── Service URLs (auto-configured in Docker, override for bare metal) ─

# PLANNER_URL=http://localhost:3001
# BUILDER_URL=http://localhost:3002
# QA_URL=http://localhost:3003
# GATE_URL=http://localhost:3004
# BOARD_URL=http://localhost:3005
# TECHNICIAN_URL=http://localhost:3006
# SECURITY_URL=http://localhost:3007
# ACTIONS_URL=http://localhost:3000
